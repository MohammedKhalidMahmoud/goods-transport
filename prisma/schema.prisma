generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum UserType {
  APP
  DASHBOARD
}

enum AppRole {
  CUSTOMER
  PROVIDER
}

enum OrderStatus {
  draft
  submitted
  pending_approval
  approved
  rejected
  published_for_offers
  offer_received
  offer_accepted
  assigned
  en_route_to_pickup
  arrived_pickup
  picked_up
  in_transit
  arrived_dropoff
  delivered
  completed
  canceled
}

enum OfferStatus {
  pending
  accepted
  rejected
  expired
  withdrawn
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  canceled
  overdue
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum DocumentStatus {
  pending
  approved
  rejected
  expired
}

enum AssignmentStatus {
  pending
  accepted
  rejected
  in_progress
  completed
  canceled
}

enum SourceType {
  individual
  company
}

enum LocationType {
  pickup
  dropoff
}

enum NotificationType {
  info
  warning
  success
  error
}

enum PaymentMethod {
  cash
  bank_transfer
  online
  wallet
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum SettlementStatus {
  pending
  processing
  completed
  failed
}

enum EarningsReportStatus {
  draft
  generating
  ready
  failed
}

// ============================================================
// CORE ACCESS
// ============================================================

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  avatarUrl    String?    @map("avatar_url")
  language     String     @default("en")
  userType     UserType   @map("user_type")
  appRole      AppRole?   @map("app_role")
  status       UserStatus @default(PENDING_VERIFICATION)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  dashboardProfile    DashboardUserProfile?
  providerProfile     ProviderProfile?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  otpVerifications    OtpVerification[]
  notifications       Notification[]
  userRoles           UserRole[]
  companyUsers        CompanyUser[]
  providerUsers       ProviderUser[]
  ordersRequested     Order[]               @relation("OrderRequester")

  @@index([status])
  @@index([userType])
  @@index([appRole])
  @@index([deletedAt])
  @@map("users")
}

model DashboardUserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  roleId    String   @map("role_id")
  myAdmin   Boolean  @default(false) @map("my_admin")
  jobTitle  String?  @map("job_title")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@map("dashboard_user_profiles")
}

model ProviderProfile {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  businessName  String   @map("business_name")
  logoUrl       String?  @map("logo_url")
  description   String?  @db.Text
  address       String?  @db.Text
  taxNumber     String?  @map("tax_number")
  licenseNumber String?  @map("license_number")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("provider_profiles")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?  @db.Text
  scopeType   String   @default("global") @map("scope_type")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]
  dashboardUsers  DashboardUserProfile[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  module      String
  action      String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  userAgent String?  @map("user_agent") @db.Text
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model OtpVerification {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  code       String
  type       String // email, phone
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("otp_verifications")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  title     String
  body      String           @db.Text
  type      NotificationType @default(info)
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ============================================================
// MASTER DATA
// ============================================================

model ServiceCategory {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  nameAr      String?  @map("name_ar")
  description String?  @db.Text
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  serviceTypes ServiceType[]

  @@map("service_categories")
}

model ServiceType {
  id                String   @id @default(uuid())
  serviceCategoryId String   @map("service_category_id")
  code              String   @unique
  name              String
  nameAr            String?  @map("name_ar")
  description       String?  @db.Text
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  orders          Order[]

  @@map("service_types")
}

model VehicleType {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  nameAr      String?  @map("name_ar")
  description String?  @db.Text
  capacity    String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  providerVehicles ProviderVehicle[]
  orders           Order[]

  @@map("vehicle_types")
}

model City {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  nameAr    String?  @map("name_ar")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cities")
}

model PricingSetting {
  id                String   @id @default(uuid())
  serviceTypeCode   String   @map("service_type_code")
  baseFare          Decimal  @default(0) @map("base_fare") @db.Decimal(12, 2)
  perKmRate         Decimal  @default(0) @map("per_km_rate") @db.Decimal(12, 2)
  perWorkerRate     Decimal  @default(0) @map("per_worker_rate") @db.Decimal(12, 2)
  floorRate         Decimal  @default(0) @map("floor_rate") @db.Decimal(12, 2)
  fragileMultiplier Decimal  @default(1) @map("fragile_multiplier") @db.Decimal(5, 2)
  currency          String   @default("SAR")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([serviceTypeCode])
  @@map("pricing_settings")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  group     String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("app_settings")
}

// ============================================================
// PROVIDERS
// ============================================================

model Provider {
  id                String    @id @default(uuid())
  name              String
  nameAr            String?   @map("name_ar")
  logoUrl           String?   @map("logo_url")
  contactEmail      String    @map("contact_email")
  contactPhone      String    @map("contact_phone")
  address           String?   @db.Text
  taxNumber         String?   @map("tax_number")
  licenseNumber     String?   @map("license_number")
  status            String    @default("active")
  isVerified        Boolean   @default(false) @map("is_verified")
  isAcceptingOrders Boolean   @default(true) @map("is_accepting_orders")
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  providerUsers        ProviderUser[]
  providerDocuments    ProviderDocument[]
  providerAvailability ProviderAvailability[]
  providerWorkers      ProviderWorker[]
  providerDrivers      ProviderDriver[]
  providerVehicles     ProviderVehicle[]
  providerWallet       ProviderWallet?
  offers               Offer[]
  assignments          Assignment[]
  commissions          Commission[]
  settlements          Settlement[]

  @@index([status])
  @@index([deletedAt])
  @@map("providers")
}

model ProviderUser {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  userId     String   @map("user_id")
  role       String   @default("provider_operator")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, userId])
  @@index([userId])
  @@map("provider_users")
}

model ProviderDocument {
  id              String         @id @default(uuid())
  providerId      String         @map("provider_id")
  documentType    String         @map("document_type")
  fileName        String         @map("file_name")
  originalName    String         @map("original_name")
  filePath        String         @map("file_path")
  mimeType        String         @map("mime_type")
  fileSize        Int            @map("file_size")
  status          DocumentStatus @default(pending)
  expiresAt       DateTime?      @map("expires_at")
  reviewedBy      String?        @map("reviewed_by")
  reviewedAt      DateTime?      @map("reviewed_at")
  rejectionReason String?        @map("rejection_reason") @db.Text
  uploadedBy      String         @map("uploaded_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, status])
  @@map("provider_documents")
}

model ProviderAvailability {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  dayOfWeek  Int      @map("day_of_week")
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_availability")
}

model ProviderWorker {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  name       String
  phone      String?
  idNumber   String?  @map("id_number")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_workers")
}

model ProviderDriver {
  id            String    @id @default(uuid())
  providerId    String    @map("provider_id")
  userId        String?   @map("user_id")
  name          String
  phone         String
  licenseNumber String?   @map("license_number")
  licenseExpiry DateTime? @map("license_expiry")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  provider    Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([providerId])
  @@index([userId])
  @@map("provider_drivers")
}

model ProviderVehicle {
  id            String   @id @default(uuid())
  providerId    String   @map("provider_id")
  vehicleTypeId String   @map("vehicle_type_id")
  plateNumber   String   @map("plate_number")
  make          String?
  model         String?
  year          Int?
  color         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  provider    Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  vehicleType VehicleType @relation(fields: [vehicleTypeId], references: [id])

  @@index([providerId])
  @@map("provider_vehicles")
}

model ProviderWallet {
  id             String   @id @default(uuid())
  providerId     String   @unique @map("provider_id")
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  pendingBalance Decimal  @default(0) @map("pending_balance") @db.Decimal(12, 2)
  totalEarnings  Decimal  @default(0) @map("total_earnings") @db.Decimal(12, 2)
  totalWithdrawn Decimal  @default(0) @map("total_withdrawn") @db.Decimal(12, 2)
  currency       String   @default("SAR")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_wallets")
}

// ============================================================
// COMPANIES
// ============================================================

model Company {
  id           String    @id @default(uuid())
  name         String
  nameAr       String?   @map("name_ar")
  logoUrl      String?   @map("logo_url")
  contactEmail String    @map("contact_email")
  contactPhone String    @map("contact_phone")
  address      String?   @db.Text
  taxNumber    String?   @map("tax_number")
  industry     String?
  status       String    @default("active")
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  companyUsers    CompanyUser[]
  billingProfiles CompanyBillingProfile[]
  approvalRules   ApprovalRule[]
  orders          Order[]
  invoices        Invoice[]

  @@index([status])
  @@index([deletedAt])
  @@map("companies")
}

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  role      String   @default("employee")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_users")
}

model CompanyBillingProfile {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  billingName      String   @map("billing_name")
  billingEmail     String   @map("billing_email")
  billingAddress   String?  @map("billing_address") @db.Text
  taxNumber        String?  @map("tax_number")
  paymentTermsDays Int      @default(30) @map("payment_terms_days")
  creditLimit      Decimal  @default(0) @map("credit_limit") @db.Decimal(12, 2)
  currency         String   @default("SAR")
  isDefault        Boolean  @default(false) @map("is_default")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_billing_profiles")
}

model ApprovalRule {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  name            String
  serviceTypeCode String?  @map("service_type_code")
  minAmount       Decimal? @map("min_amount") @db.Decimal(12, 2)
  maxAmount       Decimal? @map("max_amount") @db.Decimal(12, 2)
  approverRole    String   @map("approver_role")
  level           Int      @default(1)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive])
  @@map("approval_rules")
}

model ApprovalHistory {
  id         String         @id @default(uuid())
  orderId    String         @map("order_id")
  approverId String         @map("approver_id")
  ruleId     String?        @map("rule_id")
  status     ApprovalStatus
  notes      String?        @db.Text
  level      Int            @default(1)
  decidedAt  DateTime       @default(now()) @map("decided_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([approverId])
  @@map("approval_history")
}

// ============================================================
// OPERATIONS
// ============================================================

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique @map("order_number")
  sourceType        SourceType  @map("source_type")
  requesterId       String      @map("requester_id")
  companyId         String?     @map("company_id")
  serviceTypeId     String      @map("service_type_id")
  vehicleTypeId     String?     @map("vehicle_type_id")
  status            OrderStatus @default(draft)
  workerCount       Int         @default(1) @map("worker_count")
  isFragile         Boolean     @default(false) @map("is_fragile")
  notes             String?     @db.Text
  scheduledDate     DateTime?   @map("scheduled_date")
  scheduledTimeSlot String?     @map("scheduled_time_slot")
  estimatedPrice    Decimal?    @map("estimated_price") @db.Decimal(12, 2)
  finalPrice        Decimal?    @map("final_price") @db.Decimal(12, 2)
  currency          String      @default("SAR")
  cancelReason      String?     @map("cancel_reason") @db.Text
  completedAt       DateTime?   @map("completed_at")
  createdBy         String?     @map("created_by")
  updatedBy         String?     @map("updated_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  requester   User         @relation("OrderRequester", fields: [requesterId], references: [id])
  company     Company?     @relation(fields: [companyId], references: [id])
  serviceType ServiceType  @relation(fields: [serviceTypeId], references: [id])
  vehicleType VehicleType? @relation(fields: [vehicleTypeId], references: [id])

  locations       OrderLocation[]
  items           OrderItem[]
  attachments     OrderAttachment[]
  statusHistory   OrderStatusHistory[]
  offers          Offer[]
  assignments     Assignment[]
  approvalHistory ApprovalHistory[]
  cancellation    Cancellation?
  invoice         Invoice?
  deliveryProofs  DeliveryProof[]

  @@index([status])
  @@index([companyId, status])
  @@index([requesterId])
  @@index([createdAt])
  @@index([orderNumber])
  @@index([deletedAt])
  @@map("orders")
}

model OrderLocation {
  id           String       @id @default(uuid())
  orderId      String       @map("order_id")
  type         LocationType
  addressLine  String       @map("address_line") @db.Text
  city         String
  area         String?
  latitude     Decimal?     @db.Decimal(10, 8)
  longitude    Decimal?     @db.Decimal(11, 8)
  floor        Int?
  unit         String?
  hasElevator  Boolean      @default(false) @map("has_elevator")
  contactName  String?      @map("contact_name")
  contactPhone String?      @map("contact_phone")
  notes        String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_locations")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  name        String
  quantity    Int      @default(1)
  description String?  @db.Text
  isFragile   Boolean  @default(false) @map("is_fragile")
  weight      Decimal? @db.Decimal(10, 2)
  dimensions  String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model OrderAttachment {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  filePath     String   @map("file_path")
  mimeType     String   @map("mime_type")
  fileSize     Int      @map("file_size")
  uploadedBy   String   @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_attachments")
}

model OrderStatusHistory {
  id         String       @id @default(uuid())
  orderId    String       @map("order_id")
  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")
  changedBy  String?      @map("changed_by")
  notes      String?      @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model Offer {
  id                String      @id @default(uuid())
  orderId           String      @map("order_id")
  providerId        String      @map("provider_id")
  price             Decimal     @db.Decimal(12, 2)
  estimatedDuration String?     @map("estimated_duration")
  notes             String?     @db.Text
  status            OfferStatus @default(pending)
  validUntil        DateTime?   @map("valid_until")
  respondedAt       DateTime?   @map("responded_at")
  respondedBy       String?     @map("responded_by")
  createdBy         String?     @map("created_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  order    Order    @relation(fields: [orderId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([orderId, status])
  @@index([providerId, status])
  @@map("offers")
}

model Assignment {
  id          String           @id @default(uuid())
  orderId     String           @map("order_id")
  providerId  String           @map("provider_id")
  driverId    String?          @map("driver_id")
  status      AssignmentStatus @default(pending)
  assignedBy  String?          @map("assigned_by")
  acceptedAt  DateTime?        @map("accepted_at")
  startedAt   DateTime?        @map("started_at")
  completedAt DateTime?        @map("completed_at")
  notes       String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  order          Order           @relation(fields: [orderId], references: [id])
  provider       Provider        @relation(fields: [providerId], references: [id])
  driver         ProviderDriver? @relation(fields: [driverId], references: [id])
  trackingEvents TrackingEvent[]

  @@index([orderId])
  @@index([driverId, status])
  @@index([providerId])
  @@map("assignments")
}

model TrackingEvent {
  id           String   @id @default(uuid())
  assignmentId String   @map("assignment_id")
  eventType    String   @map("event_type")
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  data         Json?
  createdAt    DateTime @default(now()) @map("created_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, createdAt])
  @@map("tracking_events")
}

model DeliveryProof {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  type       String // photo, signature, confirmation
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  mimeType   String   @map("mime_type")
  notes      String?  @db.Text
  capturedBy String   @map("captured_by")
  capturedAt DateTime @default(now()) @map("captured_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("delivery_proofs")
}

model Cancellation {
  id          String   @id @default(uuid())
  orderId     String   @unique @map("order_id")
  reason      String   @db.Text
  canceledBy  String   @map("canceled_by")
  fee         Decimal  @default(0) @db.Decimal(12, 2)
  feeCurrency String   @default("SAR") @map("fee_currency")
  createdAt   DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("cancellations")
}

// ============================================================
// FINANCE
// ============================================================

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  orderId       String?       @unique @map("order_id")
  companyId     String?       @map("company_id")
  providerId    String?       @map("provider_id")
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount   Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  currency      String        @default("SAR")
  status        InvoiceStatus @default(draft)
  dueDate       DateTime?     @map("due_date")
  issuedAt      DateTime?     @map("issued_at")
  notes         String?       @db.Text
  createdBy     String?       @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order    Order?        @relation(fields: [orderId], references: [id])
  company  Company?      @relation(fields: [companyId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@index([companyId, status])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id             String        @id @default(uuid())
  invoiceId      String        @map("invoice_id")
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("SAR")
  method         PaymentMethod
  status         PaymentStatus @default(pending)
  transactionRef String?       @map("transaction_ref")
  notes          String?       @db.Text
  paidAt         DateTime?     @map("paid_at")
  createdBy      String?       @map("created_by")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model Commission {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  providerId String   @map("provider_id")
  orderTotal Decimal  @map("order_total") @db.Decimal(12, 2)
  rate       Decimal  @db.Decimal(5, 4)
  amount     Decimal  @db.Decimal(12, 2)
  currency   String   @default("SAR")
  createdAt  DateTime @default(now()) @map("created_at")

  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([orderId])
  @@map("commissions")
}

model Settlement {
  id          String           @id @default(uuid())
  providerId  String           @map("provider_id")
  amount      Decimal          @db.Decimal(12, 2)
  currency    String           @default("SAR")
  periodStart DateTime         @map("period_start")
  periodEnd   DateTime         @map("period_end")
  status      SettlementStatus @default(pending)
  reference   String?
  processedAt DateTime?        @map("processed_at")
  notes       String?          @db.Text
  createdBy   String?          @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId, status])
  @@map("settlements")
}

/// Snapshot / roll-up for dashboards and exports (Phase 3 jobs populate this).
model EarningsReport {
  id              String               @id @default(uuid())
  subjectType     String               @map("subject_type")
  subjectId       String?              @map("subject_id")
  periodStart     DateTime             @map("period_start")
  periodEnd       DateTime             @map("period_end")
  currency        String               @default("SAR")
  totalGross      Decimal              @default(0) @map("total_gross") @db.Decimal(12, 2)
  totalNet        Decimal              @default(0) @map("total_net") @db.Decimal(12, 2)
  totalCommission Decimal              @default(0) @map("total_commission") @db.Decimal(12, 2)
  status          EarningsReportStatus @default(draft)
  generatedAt     DateTime?            @map("generated_at")
  filePath        String?              @map("file_path")
  meta            Json?
  createdBy       String?              @map("created_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([subjectType, subjectId])
  @@index([periodStart, periodEnd])
  @@map("earnings_reports")
}

// ============================================================
// SUPPORT
// ============================================================

model IssueType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  nameAr    String?  @map("name_ar")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tickets Ticket[]

  @@map("issue_types")
}

model Ticket {
  id           String       @id @default(uuid())
  ticketNumber String       @unique @map("ticket_number")
  userId       String       @map("user_id")
  issueTypeId  String?      @map("issue_type_id")
  orderId      String?      @map("order_id")
  subject      String
  description  String       @db.Text
  status       TicketStatus @default(open)
  priority     String       @default("medium")
  assignedTo   String?      @map("assigned_to")
  resolvedAt   DateTime?    @map("resolved_at")
  closedAt     DateTime?    @map("closed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  issueType IssueType?      @relation(fields: [issueTypeId], references: [id])
  comments  TicketComment[]

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  userId     String   @map("user_id")
  body       String   @db.Text
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_comments")
}
